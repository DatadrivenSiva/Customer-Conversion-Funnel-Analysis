4.Bounce Rate Analysis
SELECT 
    Event,
    COUNT(CASE WHEN bounce_flag = 'yes' THEN 1 END) AS bounced_users,
    COUNT(*) AS total_users,
    ROUND(
        COUNT(CASE WHEN bounce_flag = 'yes' THEN 1 END) * 100.0 / COUNT(*), 2
    ) AS bounce_rate
FROM funnel_data
GROUP BY Event
ORDER BY FIELD(Event, 'Browser', 'Product View', 'Add to Cart', 'Checkout', 'Purchase');
